# Contact form email delivery (Resend — https://resend.com)
# Without these set, /api/contact will reject submissions with a clear error
# instead of silently dropping them.
RESEND_API_KEY=
# Address that receives enquiries (your inbox)
CONTACT_TO_EMAIL=
# Verified sender. Defaults to Resend's onboarding sender if unset.
# CONTACT_FROM_EMAIL="Dslash <hello@yourdomain.com>"

# Absolute base URL of the deployed site (used for SEO metadata / OG tags / sitemap)
NEXT_PUBLIC_SITE_URL=https://dslash.agency
